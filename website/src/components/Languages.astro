---
const languages = [
  { name: 'Python', ext: '.py', frameworks: 'FastAPI, Django, Flask', color: 'text-yellow-400' },
  { name: 'JavaScript', ext: '.js .jsx', frameworks: 'React, Express, Angular', color: 'text-amber-400' },
  { name: 'TypeScript', ext: '.ts .tsx', frameworks: 'Next.js, NestJS, Angular', color: 'text-blue-400' },
  { name: 'Go', ext: '.go', frameworks: '—', color: 'text-cyan-400' },
  { name: 'Rust', ext: '.rs', frameworks: '—', color: 'text-orange-400' },
  { name: 'Java', ext: '.java', frameworks: 'Spring Boot', color: 'text-red-400' },
  { name: 'C#', ext: '.cs', frameworks: 'ASP.NET', color: 'text-purple-400' },
  { name: 'Dart', ext: '.dart', frameworks: 'Flutter', color: 'text-sky-400' },
  { name: 'Kotlin', ext: '.kt', frameworks: 'Android', color: 'text-violet-400' },
  { name: 'Swift', ext: '.swift', frameworks: 'SwiftUI, UIKit', color: 'text-orange-300' },
];
---

<section id="languages" class="py-24 bg-surface-900/40">
  <div class="section-container">
    <div class="text-center mb-16">
      <h2 class="text-3xl sm:text-4xl font-bold text-white">
        <span class="gradient-text">10 languages</span>, one index
      </h2>
      <p class="mt-4 text-gray-400 text-lg max-w-2xl mx-auto">
        Tree-sitter grammars for accurate AST parsing. Framework detection identifies React components, Express routes, Django views, and more.
      </p>
    </div>

    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-5 gap-4">
      {languages.map(lang => (
        <div class="glass-card p-4 text-center hover:border-brand-500/20 transition-all duration-300">
          <div class={`text-2xl font-bold mb-1 ${lang.color}`}>{lang.name}</div>
          <div class="text-xs text-gray-500 font-mono mb-2">{lang.ext}</div>
          <div class="text-xs text-gray-400">{lang.frameworks}</div>
        </div>
      ))}
    </div>

    <div class="mt-12 text-center">
      <div class="glass-card inline-flex items-center gap-3 px-6 py-3">
        <svg class="w-5 h-5 text-brand-400" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 016 3.75h2.25A2.25 2.25 0 0110.5 6v2.25a2.25 2.25 0 01-2.25 2.25H6a2.25 2.25 0 01-2.25-2.25V6z"/><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 15.75A2.25 2.25 0 016 13.5h2.25a2.25 2.25 0 012.25 2.25V18a2.25 2.25 0 01-2.25 2.25H6A2.25 2.25 0 013.75 18v-2.25z"/><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6a2.25 2.25 0 012.25-2.25H18A2.25 2.25 0 0120.25 6v2.25A2.25 2.25 0 0118 10.5h-2.25a2.25 2.25 0 01-2.25-2.25V6z"/><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 15.75a2.25 2.25 0 012.25-2.25H18a2.25 2.25 0 012.25 2.25V18A2.25 2.25 0 0118 20.25h-2.25A2.25 2.25 0 0113.5 18v-2.25z"/></svg>
        <span class="text-sm text-gray-300"><strong class="text-white">What gets indexed:</strong> Functions, Classes, Call Graphs, Imports/Exports, API Routes, Entities, Decorators</span>
      </div>
    </div>
  </div>
</section>
