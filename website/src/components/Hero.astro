---
---

<section class="relative pt-32 pb-20 overflow-hidden">
  <!-- Gradient orbs -->
  <div class="absolute top-0 left-1/4 w-[600px] h-[600px] bg-brand-500/8 rounded-full blur-[120px] pointer-events-none"></div>
  <div class="absolute bottom-0 right-1/4 w-[400px] h-[400px] bg-brand-700/10 rounded-full blur-[100px] pointer-events-none"></div>

  <div class="section-container relative z-10">
    <!-- Badge -->
    <div class="flex justify-center mb-8">
      <a
        href="https://pypi.org/project/cortexcode/"
        target="_blank"
        rel="noopener"
        class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-brand-500/10 border border-brand-500/20 text-brand-300 text-sm hover:bg-brand-500/15 transition-colors"
      >
        <span class="w-2 h-2 rounded-full bg-accent-green animate-pulse"></span>
        v0.9.1 — CodeWiki, flow tracing, and post-index workflows
      </a>
    </div>

    <!-- Headline -->
    <h1 class="text-center text-5xl sm:text-6xl lg:text-7xl font-extrabold leading-tight tracking-tight">
      <span class="text-white">Understand your codebase.</span><br />
      <span class="gradient-text">Build a searchable codegraph.</span>
    </h1>

    <p class="mt-6 text-center text-lg sm:text-xl text-gray-400 max-w-3xl mx-auto leading-relaxed">
      CortexCode uses <strong class="text-gray-200">AST parsing</strong> to build a structured codegraph of your codebase.
      Explore symbols, trace flows, generate docs and diagrams, produce CodeWiki pages, and connect AI tools through MCP.
    </p>

    <!-- CTA buttons -->
    <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        href="#install"
        class="inline-flex items-center gap-2 px-8 py-3.5 rounded-xl bg-brand-500 hover:bg-brand-400 text-white font-semibold text-base transition-all shadow-lg shadow-brand-500/25 hover:shadow-brand-400/30"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
        Get Started
      </a>
      <a
        href="https://github.com/naveen-joshi/cortexcode"
        target="_blank"
        rel="noopener"
        class="inline-flex items-center gap-2 px-8 py-3.5 rounded-xl bg-surface-700/60 hover:bg-surface-600/60 border border-white/[0.06] text-gray-200 font-semibold text-base transition-all"
      >
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
        View on GitHub
      </a>
    </div>

    <!-- Product visual -->
    <div class="mt-16 max-w-2xl mx-auto">
      <div class="glass-card glow-border p-6">
        <div class="flex items-center gap-3 mb-4">
          <div class="flex gap-1.5">
            <span class="w-3 h-3 rounded-full bg-accent-rose/80"></span>
            <span class="w-3 h-3 rounded-full bg-accent-amber/80"></span>
            <span class="w-3 h-3 rounded-full bg-accent-green/80"></span>
          </div>
          <span class="text-xs text-gray-500 font-mono">terminal</span>
        </div>
        <pre class="text-sm leading-relaxed font-mono overflow-x-auto"><code><span class="text-gray-500">$</span> <span class="text-brand-300">cc</span> index

<span class="text-brand-400">╭──────────── Indexed Project ───────────╮</span>
<span class="text-brand-400">│</span> Files               <span class="text-white">166</span>                <span class="text-brand-400">│</span>
<span class="text-brand-400">│</span> Symbols             <span class="text-accent-amber">722</span>                <span class="text-brand-400">│</span>
<span class="text-brand-400">│</span> Languages           <span class="text-accent-green">py, ts, js</span>          <span class="text-brand-400">│</span>
<span class="text-brand-400">│</span>                                         <span class="text-brand-400">│</span>
<span class="text-brand-400">│</span> Suggested reports   <span class="text-white">overview, tech</span>     <span class="text-brand-400">│</span>
<span class="text-brand-400">│</span> Suggested diagrams  <span class="text-white">architecture, flow</span> <span class="text-brand-400">│</span>
<span class="text-brand-400">╰─────────────────────────────────────────╯</span></code></pre>
      </div>
    </div>
  </div>
</section>
