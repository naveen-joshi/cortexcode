---
const groups = [
  {
    name: 'analyze',
    description: 'Code exploration & analysis',
    commands: [
      { cmd: 'cc analyze context "auth"', desc: 'Get AI-ready context' },
      { cmd: 'cc analyze trace login', desc: 'Trace call flow' },
      { cmd: 'cc analyze flow auth', desc: 'Concept-based flow' },
      { cmd: 'cc analyze impact handleUser', desc: 'Change impact' },
      { cmd: 'cc analyze dead-code', desc: 'Find unused symbols' },
      { cmd: 'cc analyze complexity', desc: 'Complexity metrics' },
    ],
  },
  {
    name: 'ai',
    description: 'Natural language understanding',
    commands: [
      { cmd: 'cc ai ask "how does auth work?"', desc: 'Ask about code' },
      { cmd: 'cc ai explain handleAuth', desc: 'Explain a symbol' },
      { cmd: 'cc ai docs', desc: 'AI documentation' },
      { cmd: 'cc ai wiki --open', desc: 'Generate CodeWiki' },
    ],
  },
  {
    name: 'generate',
    description: 'Docs, diagrams & reports',
    commands: [
      { cmd: 'cc generate docs --open', desc: 'Interactive HTML docs' },
      { cmd: 'cc generate diagrams --viz', desc: 'D3.js visualization' },
      { cmd: 'cc generate report', desc: 'Terminal reports' },
    ],
  },
  {
    name: 'serve',
    description: 'Long-running services',
    commands: [
      { cmd: 'cc serve watch', desc: 'Auto-reindex on save' },
      { cmd: 'cc serve dashboard', desc: 'Live web dashboard' },
      { cmd: 'cc serve lsp', desc: 'Language server' },
    ],
  },
];
---

<section id="cli" class="py-24">
  <div class="section-container">
    <div class="text-center mb-16">
      <h2 class="text-3xl sm:text-4xl font-bold text-white">
        One CLI, <span class="gradient-text">organized commands</span>
      </h2>
      <p class="mt-4 text-gray-400 text-lg max-w-2xl mx-auto">
        Use <code class="text-brand-300 bg-brand-500/10 px-1.5 py-0.5 rounded text-sm">cc</code> or <code class="text-brand-300 bg-brand-500/10 px-1.5 py-0.5 rounded text-sm">cortexcode</code> — both work. Commands are grouped into logical namespaces.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {groups.map(group => (
        <div class="glass-card overflow-hidden">
          <div class="px-5 py-3 border-b border-white/[0.04] flex items-center justify-between">
            <div>
              <span class="text-brand-400 font-semibold text-sm">cc {group.name}</span>
              <span class="text-gray-500 text-xs ml-2">— {group.description}</span>
            </div>
          </div>
          <div class="p-4 space-y-2">
            {group.commands.map(c => (
              <div class="flex items-start gap-3 group/cmd">
                <code class="text-xs font-mono text-gray-300 bg-surface-700/60 px-2 py-1 rounded whitespace-nowrap shrink-0">
                  {c.cmd}
                </code>
                <span class="text-xs text-gray-500 pt-1">{c.desc}</span>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
